// Two-bar layout:
//   TOP    — zjstatus: session name | tabs | sysinfo (disk/mem/cpu)
//   BOTTOM — built-in status-bar: the keybind / mode "mappings"
// sysinfo migrated here from tmux; tmux is now just a session detacher for agents.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
                format_left   "#[fg=blue,bold] {session} "
                format_center "{tabs}"
                format_right  "#[fg=green]{command_sysinfo}#[default] "
                format_space  ""

                tab_normal    "#[fg=8] {name} "
                tab_active    "#[fg=blue,bold] {name} "

                // run the sysinfo script every 5s; it prints plain text, styled above
                command_sysinfo_command    "sh -c $HOME/.bin/sysinfo"
                command_sysinfo_format     "{stdout}"
                command_sysinfo_interval   "5"
                command_sysinfo_rendermode "static"
            }
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
}
