{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "app": {
    "appearance": "dark",
    "preferredEditor": "nvim",
    "openMarkdownInCmuxViewer": true,
    "reorderOnNotification": false,              // keep workspaces pinned in sidebar order
    "warnBeforeQuit": true,
    "warnBeforeClosingTab": false,
    "sendAnonymousTelemetry": false
  },

  "terminal": {
    "showScrollBar": false
  },

  "notifications": {
    "dockBadge": true,
    "showInMenuBar": true,
    "unreadPaneRing": true,
    "sound": "default"
  },

  "sidebar": {
    "branchLayout": "inline",
    "showBranchDirectory": true,
    "showPullRequests": true,
    "showPorts": true,
    "showLog": false
  },

  "browser": {
    "defaultSearchEngine": "duckduckgo",
    "theme": "dark",
    "openTerminalLinksInCmuxBrowser": true
  },

  "automation": {
    "claudeCodeIntegration": true,
    "socketControlMode": "cmuxOnly",
    "portBase": 9100,
    "portRange": 10
  },

  // Bindings
  "shortcuts": {
    "showModifierHoldHints": true,
    "bindings": {

      // Copy mode
      "toggleTerminalCopyMode":       "cmd+ctrl+y",

      // Sidebar
      "toggleSidebar":                "cmd+b",         // left sidebar
      "toggleFileExplorer":           "cmd+e",         // right sidebar — experimental: not in schema enum, editor will warn
      "focusRightSidebar":            "cmd+shift+e",

      // Sidebar — modes (context: right sidebar focused)
      "switchRightSidebarToFiles":    "ctrl+1",
      "switchRightSidebarToFind":     "ctrl+2",
      "switchRightSidebarToSessions": "ctrl+3",
      "switchRightSidebarToFeed":     "ctrl+4",
      "switchRightSidebarToDock":     "ctrl+5",


      // Splits (panes) — management
      "splitRight":                   "cmd+d",
      "splitDown":                    "cmd+shift+d",
      "splitBrowserRight":            "cmd+i",
      "splitBrowserDown":             "cmd+shift+i",
      "equalizeSplits":               "cmd+ctrl+m",
      "toggleSplitZoom":              "cmd+ctrl+z",

      // Splits (panes) — navigation
      "focusLeft":                    "cmd+ctrl+h",
      "focusRight":                   "cmd+ctrl+l",
      "focusUp":                      "cmd+ctrl+k",
      "focusDown":                    "cmd+ctrl+j",

      // Surfaces (windows) — management
      "newSurface":                   "cmd+t",
      "renameTab":                    "cmd+ctrl+,",             // context: terminal pane focused
      "closeTab":                     "cmd+w",
      "closeOtherTabsInPane":         "cmd+ctrl+w",
      "reopenClosedBrowserPanel":     "cmd+shift+z",
      "saveFilePreview":              "cmd+s",             // context: text preview focused

      // Surfaces (windows) — navigation
      "nextSurface":                  "cmd+shift+]",
      "prevSurface":                  "cmd+shift+[",
      "selectSurfaceByNumber":        "ctrl+1",            // covers ctrl+1..9; context: sidebar NOT focused

      // Workspaces (sessions) — management
      "newTab":                       "cmd+n",             // legacy action id; actually "new workspace"
      "openFolder":                   "cmd+o",
      "closeWorkspace":               "cmd+shift+w",
      "renameWorkspace":              "cmd+ctrl+4",
      "editWorkspaceDescription":     "opt+cmd+e",
      "reopenPreviousSession":        "cmd+shift+o",

      // Workspaces (sessions) — navigation
      "goToWorkspace":                "cmd+p",             // workspace switcher
      "nextSidebarTab":               "ctrl+cmd+n",        // next workspace
      "prevSidebarTab":               "ctrl+cmd+p",        // prev workspace
      "selectWorkspaceByNumber":      "cmd+1",             // covers cmd+1..9 internally

      // Command palette
      "commandPalette":               "cmd+shift+p",
      "commandPaletteNext":           "ctrl+n",            // context: palette open
      "commandPalettePrevious":       "ctrl+p",            // context: palette open

      // Browser — navigation
      "openBrowser":                  "cmd+shift+t",
      "focusBrowserAddressBar":       "cmd+l",
      "browserBack":                  "cmd+[",
      "browserForward":               "cmd+]",
      "browserReload":                "cmd+r",             // context: browser focused (same chord as renameTab)

      // Browser — zoom
      "browserZoomIn":                "cmd+=",
      "browserZoomOut":               "cmd+-",
      "browserZoomReset":             "cmd+0",

      // Browser — devtools
      "toggleBrowserDeveloperTools":  "opt+cmd+i",
      "showBrowserJavaScriptConsole": "opt+cmd+c",
      "toggleReactGrab":              "cmd+shift+g",

      // Find
      "find":                         "cmd+f",
      "findInDirectory":              "cmd+shift+f",
      "findNext":                     "cmd+g",
      "findPrevious":                 "cmd+shift+g",
      "hideFind":                     "opt+cmd+f",
      "useSelectionForFind":          "cmd+e",

      // Notifications
      "showNotifications":            "cmd+m",
      "jumpToUnread":                 "cmd+shift+u",
      "triggerFlash":                 "cmd+shift+h",

      // App — host windows
      "newWindow":                    "cmd+shift+ctrl+n",       // new OS window
      "closeWindow":                  "cmd+shift+ctrl+w",
      "toggleFullScreen":             "ctrl+cmd+f",
      "showHideAllWindows":           "ctrl+opt+cmd+.",    // system-wide hotkey
      "quit":                         "cmd+q",

      // App — misc
      "openSettings":                 "cmd+,",
      "sendFeedback":                 "opt+cmd+f",

      // Source
      "reloadConfiguration":          "cmd+ctrl+r"
    }
  }
}
