# Ghostty config 

# Theme
# `ghostty +list-themes`.
theme = Nightfox

macos-titlebar-style = tabs

## Font
font-family = Dejavu Sans Mono Nerd Font
font-size = 12.0

## Cursor
cursor-style = block
cursor-style-blink = false

## Window
window-padding-x = 6
window-padding-y = 4
window-padding-balance = true
window-theme = ghostty

## Panes
unfocused-split-opacity = 1.0

# Keybinds
macos-option-as-alt = true

keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

keybind = super+shift+enter=toggle_split_zoom
keybind = super+o=goto_split:previous
keybind = super+shift+o=goto_split:next

keybind = super+ctrl+k=goto_split:up
keybind = super+ctrl+j=goto_split:down
keybind = super+ctrl+h=goto_split:left
keybind = super+ctrl+l=goto_split:right

keybind = super+ctrl+u=scroll_page_fractional:-0.25
keybind = super+ctrl+d=scroll_page_fractional:0.25

keybind = super+ctrl+arrow_up=resize_split:up,10
keybind = super+ctrl+arrow_down=resize_split:down,10
keybind = super+ctrl+arrow_left=resize_split:left,10
keybind = super+ctrl+arrow_right=resize_split:right,10

keybind = super+ctrl+==equalize_splits

## Tabs
keybind = super+t=new_tab

keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8

keybind = super+l=prompt_tab_title
keybind = super+shift+l=prompt_surface_title

## Float
keybind = super+ctrl+enter=toggle_quick_terminal

## Claude Code
# keybind = shift+enter=text:\x1b\r

## Reload Config
keybind = super+r=reload_config

# Misc.
mouse-hide-while-typing = true
quick-terminal-position = center
window-new-tab-position = current
window-inherit-working-directory = true
copy-on-select = clipboard
confirm-close-surface = false
