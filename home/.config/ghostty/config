# Ghostty config — read by cmux on startup.
# Reload from cmux: Cmd+Shift+, (reloadConfiguration).

# Theme — Adwaita Dark, bundled with ghostty / cmux.app.
# Available variants: Adwaita, Adwaita Dark.
# Browse the full list with `ghostty +list-themes`.
theme = Adwaita Dark

# Font — installed via Brewfile (font-iosevka-nerd-font).
font-family = Iosevka Nerd Font
font-size = 12.0

# Cursor.
cursor-style = block
cursor-style-blink = false

# Padding around the terminal contents.
window-padding-x = 6
window-padding-y = 4
window-padding-balance = true

# Treat the macOS Option key as Alt so `M-` bindings (e.g. tmux M-Tab) work.
macos-option-as-alt = true

# Quality-of-life.
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false

# Splits — keep unfocused panes readable while still signalling focus.
# 1.0 disables dimming entirely; 0.92 leaves a subtle hint.
unfocused-split-opacity = 0.92
