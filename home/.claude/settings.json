{
  "permissions": {
    "allow": [
      "Bash(glab *)",
      "Bash(tmux *)",
      "Bash(printenv TMUX)",
      "mcp__atlassian__*",
      "mcp__claude_ai_Atlassian__*"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash /Users/dduclos-cavalcanti/.macfiles/home/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
