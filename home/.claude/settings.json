{
  "permissions": {
    "allow": [
      "Bash(glab *)",
      "Bash(tmux *)",
      "Bash(printenv TMUX)",
      "mcp__atlassian__*",
      "mcp__claude_ai_Atlassian__*",
      "Bash(aws cloudformation delete-stack:*)",
      "Bash(aws cloudformation continue-update-rollback:*)",
      "Bash(cdk destroy:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/start-signal.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/prompt-signal.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/stop-signal.sh done",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/notif-signal.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/dduclos-cavalcanti/.macfiles/home/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "agentic-scale@ripple-ai-marketplace": true,
    "planning-suite@ripple-ai-marketplace": true
  },
  "extraKnownMarketplaces": {
    "ripple-ai-marketplace": {
      "source": {
        "source": "git",
        "url": "git@gitlab.com:ripple/ai/claude-marketplace.git"
      }
    }
  },
  "effortLevel": "medium",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "autoUpdatesChannel": "latest"
}
