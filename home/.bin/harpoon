#!/bin/sh
# harpoon — minimal tmux session bookmarker (à la Chaitanyabsprip/tmux-harpoon).
# An ordered list of `name=path` bookmarks you jump to by index; jumping
# recreates the session at its path if it isn't running, so a slot survives the
# session being killed.
#
#   harpoon add        bookmark the current session
#   harpoon go <n>     jump to bookmark n (create at its path if needed)
#   harpoon pick       fzf-pick a bookmark and jump
#   harpoon list       show numbered bookmarks
#   harpoon rm <n>     drop bookmark n
#   harpoon edit       open the list in $EDITOR

file="${XDG_CACHE_HOME:-$HOME/.cache}/harpoon"
mkdir -p "$(dirname "$file")"
touch "$file"

case "$1" in
    add)
        entry=$(tmux display -p '#{session_name}=#{session_path}')
        name=${entry%%=*}
        # drop any existing line for this session, then append (dedup)
        { awk -F= -v n="$name" '$1 != n' "$file"; printf '%s\n' "$entry"; } \
            > "$file.tmp" && mv "$file.tmp" "$file"
        tmux display "harpoon: tracked $name"
        ;;
    go)
        line=$(sed -n "${2}p" "$file")
        [ -z "$line" ] && { tmux display "harpoon: no bookmark $2"; exit 1; }
        name=${line%%=*}
        path=${line#*=}
        tmux has-session -t "=$name" 2>/dev/null || tmux new-session -ds "$name" -c "$path"
        tmux switch-client -t "=$name"
        ;;
    pick)
        line=$(nl -ba "$file" | fzf --reverse --prompt='harpoon> ') || exit 0
        "$0" go "$(printf '%s' "$line" | awk '{print $1}')"
        ;;
    list)
        nl -ba "$file"
        ;;
    rm)
        awk -v n="$2" 'NR != n' "$file" > "$file.tmp" && mv "$file.tmp" "$file"
        ;;
    edit)
        "${EDITOR:-vi}" "$file"
        ;;
    *)
        echo "usage: harpoon {add|go <n>|pick|list|rm <n>|edit}" >&2
        exit 2
        ;;
esac
