#!/bin/sh
# sysinfo â€” disk / mem / cpu usage as PLAIN text for a status bar; the consumer
# (zellij/zjstatus top bar) applies color. Output:  َ°‹ٹ  67% َ°چ›  20% َ°»    8%
# Icons (Material Design): َ°‹ٹ disk U+F02CA  َ°چ› mem U+F035B  َ°»  cpu U+F0EE0
#
# df $HOME, not /: on macOS / is the sealed system volume (~8%); the writable
# Data volume (where files live) is the meaningful fill level.
disk=$(df "$HOME" | awk 'NR==2 {gsub(/%/,"",$5); print $5}')
mem=$(memory_pressure 2>/dev/null | awk -F': ' '/free percentage/ {gsub(/%/,"",$2); print 100-$2}')
cpu=$(ps -A -o %cpu= | awk -v n="$(getconf _NPROCESSORS_ONLN)" '{s+=$1} END {printf "%d", s/n}')

printf 'َ°‹ٹ %3s%% َ°چ› %3s%% َ°»  %3s%%\n' "$disk" "$mem" "$cpu"
