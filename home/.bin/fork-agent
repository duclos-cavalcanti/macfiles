#!/bin/sh
# fork-agent — fork the Claude Code agent running in a tmux pane into a new
# "fork" window (same session), via claude's native --fork-session (the original
# conversation is left untouched).
#
# Resolution: look at the pane's process; if it's `claude --agent <name>`, find
# that agent's transcript (newest .jsonl in the cwd's project dir whose
# agentSetting matches <name>) and resume it forked. A plain claude (no --agent)
# falls back to --continue (most recent conversation in the cwd).
#
# Usage (from tmux): fork-agent <pane_pid> <pane_cwd>

pane_pid="$1"
cwd="$2"

note() { tmux display "fork: $1"; }

# Find the claude process in the pane: the pane's own process, else a child.
cmd="$(ps -o command= -p "$pane_pid" 2>/dev/null)"
case "$cmd" in
    *claude*) ;;
    *)
        child="$(pgrep -P "$pane_pid" -f claude 2>/dev/null | head -1)"
        [ -n "$child" ] && cmd="$(ps -o command= -p "$child" 2>/dev/null)"
        ;;
esac
case "$cmd" in
    *claude*) ;;
    *) note "no claude process in this pane"; exit 1 ;;
esac

# The --agent flag, if present (handles `--agent X` and `--agent=X`).
agent="$(printf '%s\n' "$cmd" | sed -n 's/.*--agent[ =]\([^ ]*\).*/\1/p')"

if [ -n "$agent" ]; then
    # Newest transcript in this cwd's project dir whose agentSetting == agent.
    proj="$HOME/.claude/projects/$(printf '%s' "$cwd" | sed 's#[/.]#-#g')"
    newest=""
    for f in "$proj"/*.jsonl; do
        [ -e "$f" ] || continue
        as="$(head -1 "$f" | python3 -c 'import sys,json;print(json.load(sys.stdin).get("agentSetting") or "")' 2>/dev/null)"
        [ "$as" = "$agent" ] || continue
        { [ -z "$newest" ] || [ "$f" -nt "$newest" ]; } && newest="$f"
    done
    [ -n "$newest" ] || { note "no transcript for agent '$agent' here"; exit 1; }
    resume="--resume $(basename "$newest" .jsonl)"
else
    resume="--continue"
fi

tmux new-window -n fork -c "$cwd" "claude $resume --fork-session"
